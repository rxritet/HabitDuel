rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId);

      match /badges/{badgeId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }

      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }

      match /xp/{docId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }

      match /weekStats/{weekId} {
        allow read, write: if isOwner(userId);
      }

      match /achievements/{achievementId} {
        allow read, write: if isOwner(userId);
      }

      match /stats/{statId} {
        allow read, write: if isOwner(userId);
      }

      match /friends/{friendId} {
        allow read, write: if isOwner(userId);
      }

      match /friendRequests/{requestId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if signedIn() && request.resource.data.fromUserId == request.auth.uid;
      }

      match /boosters/{boosterId} {
        allow read, write: if isOwner(userId);
      }

      match /currency/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /avatars/{avatarId} {
        allow read, write: if isOwner(userId);
      }

      match /inventory/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /quests/{dateKey} {
        allow read, write: if isOwner(userId);

        match /daily/{questId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /eventRewards/{rewardId} {
        allow read, write: if isOwner(userId);
      }

      match /events/{eventId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /duels/{duelId} {
      function duelData() {
        return resource.data;
      }

      function persistedDuelData() {
        return get(/databases/$(database)/documents/duels/$(duelId)).data;
      }

      function isParticipant() {
        return signedIn() && request.auth.uid in duelData().participantIds;
      }

      function isInvitedOpponent() {
        return signedIn() &&
          duelData().status == 'pending' &&
          request.auth.uid == duelData().opponentId;
      }

      function isOpenLobby() {
        return duelData().status == 'open';
      }

      function isParticipantInPersistedDuel() {
        return signedIn() && request.auth.uid in persistedDuelData().participantIds;
      }

      function isInvitedOpponentInPersistedDuel() {
        return signedIn() &&
          persistedDuelData().status == 'pending' &&
          request.auth.uid == persistedDuelData().opponentId;
      }

      function isOpenLobbyInPersistedDuel() {
        return persistedDuelData().status == 'open';
      }

      function canAcceptPendingDuel() {
        return signedIn() &&
          duelData().status == 'pending' &&
          request.auth.uid == duelData().opponentId &&
          !(request.auth.uid in duelData().participantIds) &&
          request.auth.uid in request.resource.data.participantIds &&
          request.resource.data.status == 'active' &&
          request.resource.data.participantIds.size() == duelData().participantIds.size() + 1 &&
          request.resource.data.diff(duelData()).changedKeys().hasOnly([
            'status',
            'startsAt',
            'participantIds',
            'updatedAt',
          ]);
      }

      function canJoinOpenDuel() {
        return signedIn() &&
          duelData().status == 'open' &&
          !(request.auth.uid in duelData().participantIds) &&
          request.auth.uid in request.resource.data.participantIds &&
          request.resource.data.participantIds.size() == duelData().participantIds.size() + 1 &&
          request.resource.data.diff(duelData()).changedKeys().hasOnly([
            'participantIds',
            'updatedAt',
          ]);
      }

      allow read: if signedIn() && (isParticipant() || isOpenLobby() || isInvitedOpponent());
      allow create: if signedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update: if isParticipant() || canJoinOpenDuel() || canAcceptPendingDuel();
      allow delete: if signedIn() && request.auth.uid == resource.data.creatorId;

      match /participants/{participantId} {
        allow read: if signedIn() && (
          isParticipantInPersistedDuel() ||
          isOpenLobbyInPersistedDuel() ||
          isInvitedOpponentInPersistedDuel()
        );
        allow write: if signedIn() &&
          (request.auth.uid == participantId || isParticipantInPersistedDuel());
      }

      match /checkins/{checkinId} {
        allow read: if isParticipantInPersistedDuel();
        allow create: if isParticipantInPersistedDuel() &&
          request.auth.uid == request.resource.data.userId;
        allow update, delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isParticipantInPersistedDuel();
        allow create: if isParticipantInPersistedDuel() &&
          request.auth.uid == request.resource.data.senderId;
        allow update, delete: if false;
      }
    }

    match /invites/{inviteCode} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == request.resource.data.creatorId;
      allow update: if signedIn();
      allow delete: if signedIn() && request.auth.uid == resource.data.creatorId;
    }

    match /shop/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /seasons/{seasonId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
